{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "dashboard.html", "use": "@vercel/static" },
    { "src": "phone_sender.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/dashboard.html", "dest": "/dashboard.html" },
    { "src": "/phone_sender.html", "dest": "/phone_sender.html" }
  ]
}
